{
  "name": "trello-mcp",
  "version": "1.0.0",
  "description": "MCP server for Trello — board, card, member, label, description, and due-date operations from Claude or any MCP client.",
  "main": "dist/index.js",
  "bin": {
    "trello-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sewon-supernova/trello-mcp.git"
  },
  "homepage": "https://github.com/sewon-supernova/trello-mcp#readme",
  "bugs": {
    "url": "https://github.com/sewon-supernova/trello-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx ./src/index.ts",
    "docker:build": "docker build -t trello-mcp .",
    "docker:run": "docker run --rm -i --env-file .env trello-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trello",
    "claude",
    "claude-code",
    "agent"
  ],
  "author": "sewon-supernova",
  "contributors": [
    "Lionel Arce (original author)"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}